# Copy this file to .env and fill in the values.
# Kubernetes env vars always take precedence over .env values.

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://analyzer:analyzer-pass-2026@analyzer-postgres:5432/analyzer

# ── MinIO (object storage) ─────────────────────────────────────────────────
MINIO_ENDPOINT=minio.minio.svc.cluster.local:9000
MINIO_BUCKET=meeting-analyzer
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# ── Keycloak (authentication) ──────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak.keycloak.svc.cluster.local:8080
KEYCLOAK_REALM=mycluster
KEYCLOAK_CLIENT_ID=meeting-analyzer
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_CALLBACK_URL=https://<your-host>/meeting-analyzer/auth/callback
KEYCLOAK_EXTERNAL_URL=
SESSION_SECRET_KEY=
APP_PATH_PREFIX=/meeting-analyzer

# ── LLM / AI ───────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
LLM_RUNNER_URL=http://llm-runner.llm-runner.svc.cluster.local:8000

# ── Google Drive integration ───────────────────────────────────────────────
GOOGLE_PICKER_CLIENT_ID=
GOOGLE_PICKER_APP_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=https://<your-host>/drive/callback

# ── Whisper STT ────────────────────────────────────────────────────────────
WHISPER_URL=http://whisper:9000
WHISPER_LIVE_URL=ws://whisper-live:9090
PIPER_TTS_URL=http://piper-tts:5000

# ── LiveKit (voice) ────────────────────────────────────────────────────────
LIVEKIT_WS_URL=wss://<your-host>
LIVEKIT_INTERNAL_URL=http://livekit-service.robert.svc.cluster.local:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Team chat (Matrix) ─────────────────────────────────────────────────────
TEAM_CHAT_HOMESERVER=
TEAM_CHAT_TOKEN=
TEAM_CHAT_USER_ID=
TEAM_CHAT_ROOM_ID=
